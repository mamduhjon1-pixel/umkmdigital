rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Versi testing: user login bisa upload/baca file agar semua fitur berjalan saat uji coba.
    // Project saat ini mayoritas pakai Cloudinary, tapi rules ini aman disimpan kalau nanti Firebase Storage dipakai.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
